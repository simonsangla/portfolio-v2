# Public base URL for the deployed site. Drives sitemap, OG, and canonical URLs.
# In Vercel: set to the production domain (e.g. https://simonsangla.com).
NEXT_PUBLIC_SITE_URL=https://simonsangla.com

# Tally intake form URL. Required in production (build asserts).
# Create form at https://tally.so, copy the "share" URL here.
NEXT_PUBLIC_TALLY_URL=https://tally.so/r/XXXXXX
